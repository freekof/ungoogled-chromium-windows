@@ -344,6 +346,15 @@ void OfflineAudioContext::FireCompletionEvent() {
   AudioBuffer* rendered_buffer = DestinationHandler().RenderedBuffer();
+  if (fp_config::NoiseEnabled("audio_context") && rendered_buffer) {
+    for (unsigned channel = 0; channel < rendered_buffer->numberOfChannels(); ++channel) {
+      DOMFloat32Array* data = rendered_buffer->getChannelData(channel);
