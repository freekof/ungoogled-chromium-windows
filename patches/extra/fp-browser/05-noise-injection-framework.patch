+
+#ifndef BASE_FP_CONFIG_FP_NOISE_H_
+#define BASE_FP_CONFIG_FP_NOISE_H_
+
+#include <stddef.h>
+#include <stdint.h>
+
+#include <algorithm>
+
+#include "base/fp_config/fp_config.h"
+
+namespace fp_noise {
+
+inline uint8_t ByteNoise(uint64_t salt) {
+  return static_cast<uint8_t>(fp_config::StableNoiseUnit(salt) * 3.0);
+}
+
+inline void InjectBytes(uint8_t* data, size_t size, uint64_t salt) {
+  if (!data || size == 0) {
+    return;
+  }
+  for (size_t i = 0; i < size; i += 97) {
+    uint8_t noise = ByteNoise(salt + i);
+    data[i] = static_cast<uint8_t>(std::clamp<int>(data[i] + noise - 1, 0, 255));
+  }
+}
+
+inline float InjectFloat(float value, uint64_t salt, float amplitude) {
+  return value + static_cast<float>(fp_config::StableNoise(salt, amplitude));
+}
+
+inline double InjectDouble(double value, uint64_t salt, double amplitude) {
+  return value + fp_config::StableNoise(salt, amplitude);
+}
+
+}  // namespace fp_noise
+
+#endif  // BASE_FP_CONFIG_FP_NOISE_H_
