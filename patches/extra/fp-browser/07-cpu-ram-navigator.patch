# Fingerprint browser: navigator CPU and RAM overrides.

--- a/third_party/blink/renderer/core/frame/navigator_concurrent_hardware.cc
+++ b/third_party/blink/renderer/core/frame/navigator_concurrent_hardware.cc
@@ -5,6 +5,7 @@
 #include "third_party/blink/renderer/core/frame/navigator_concurrent_hardware.h"
 
+#include "base/fp_config/fp_config.h"
 #include "base/system/sys_info.h"
 
 namespace blink {
@@ -16,6 +17,11 @@ unsigned NavigatorConcurrentHardware::hardwareConcurrency() const {
+  if (std::optional<int> cpu_cores = fp_config::GetInt("cpu_cores")) {
+    if (*cpu_cores > 0 && *cpu_cores <= 128) {
+      return static_cast<unsigned>(*cpu_cores);
+    }
+  }
   return static_cast<unsigned>(base::SysInfo::NumberOfProcessors());
 }
--- a/third_party/blink/renderer/core/frame/navigator_device_memory.cc
+++ b/third_party/blink/renderer/core/frame/navigator_device_memory.cc
@@ -5,6 +5,7 @@
 #include "third_party/blink/renderer/core/frame/navigator_device_memory.h"
 
+#include "base/fp_config/fp_config.h"
 #include "third_party/blink/renderer/platform/instrumentation/use_counter.h"
 #include "third_party/blink/renderer/platform/runtime_enabled_features.h"
 
@@ -18,6 +19,11 @@ float NavigatorDeviceMemory::deviceMemory() const {
+  if (std::optional<int> memory = fp_config::GetInt("device_memory_gb")) {
+    if (*memory > 0 && *memory <= 128) {
+      return static_cast<float>(*memory);
+    }
+  }
   return ApproximatedDeviceMemory::GetApproximatedDeviceMemory();
 }
