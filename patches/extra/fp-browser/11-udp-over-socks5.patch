 #include "chrome/browser/browser_process.h"
 #include "chrome/browser/net/profile_network_context_service.h"
@@ -86,6 +87,14 @@ void ProxyConfigMonitor::AddToNetworkContextParams(
   network_context_params->initial_proxy_config = proxy_config;
+  std::string proxy_uri = fp_config::ProxyUri();
+  if (!proxy_uri.empty()) {
+    net::ProxyConfig fixed_proxy;
+    fixed_proxy.proxy_rules().ParseFromString(proxy_uri);
+    fixed_proxy.proxy_rules().bypass_rules.Clear();
+    network_context_params->initial_proxy_config =
+        net::ProxyConfigWithAnnotation::CreateDirect();
+    network_context_params->initial_proxy_config->value() = fixed_proxy;
+  }
 }
