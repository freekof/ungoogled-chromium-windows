+// found in the LICENSE file.
+
+#ifndef NET_SOCKET_FP_SOCKS5_UDP_CLIENT_H_
+#define NET_SOCKET_FP_SOCKS5_UDP_CLIENT_H_
+
+#include <stdint.h>
+
+#include <string>
+#include <vector>
+
+#include "net/base/ip_endpoint.h"
+
+namespace net {
+namespace fp_socks5_udp {
+
+inline std::vector<uint8_t> BuildUdpAssociatePacket(
+    const IPEndPoint& target,
+    base::span<const uint8_t> payload) {
+  std::vector<uint8_t> packet;
+  packet.push_back(0x00);
+  packet.push_back(0x00);
+  packet.push_back(0x00);
+  if (target.address().IsIPv4()) {
+    packet.push_back(0x01);
+  } else if (target.address().IsIPv6()) {
+    packet.push_back(0x04);
+  } else {
+    return {};
+  }
+  const auto bytes = target.address().bytes();
+  packet.insert(packet.end(), bytes.begin(), bytes.end());
+  packet.push_back(static_cast<uint8_t>((target.port() >> 8) & 0xff));
+  packet.push_back(static_cast<uint8_t>(target.port() & 0xff));
+  packet.insert(packet.end(), payload.begin(), payload.end());
+  return packet;
+}
+
+}  // namespace fp_socks5_udp
+}  // namespace net
+
+#endif  // NET_SOCKET_FP_SOCKS5_UDP_CLIENT_H_
