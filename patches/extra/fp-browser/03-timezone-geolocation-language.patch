 namespace blink {
@@ -24,5 +25,10 @@ AtomicString NavigatorLanguage::language() {
   const Vector<AtomicString>& languages = this->languages();
   if (!languages.empty())
     return languages[0];
+  if (std::optional<std::string> language =
