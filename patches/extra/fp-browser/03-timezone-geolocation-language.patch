@@ -42,4 +47,19 @@ const Vector<AtomicString>& NavigatorLanguage::languages() {
     EnsureUpdatedLanguage();
   }
+  std::vector<std::string> configured_languages =
+      fp_config::ModeAllowsOverride("language.mode")
+          ? fp_config::GetStringList("languages")
+          : std::vector<std::string>();
+  if (!configured_languages.empty()) {
+    languages_.clear();
+    for (const std::string& language : configured_languages) {
+      languages_.push_back(AtomicString::FromUTF8(language));
+    }
+  } else if (std::optional<std::string> language =
+                 fp_config::GetString("language.value");
+             fp_config::ModeAllowsOverride("language.mode") && language) {
+    languages_.clear();
+    languages_.push_back(AtomicString::FromUTF8(*language));
+  }
   return languages_;
 }
--- a/chrome/browser/renderer_preferences_util.cc
