@@ -5,5 +5,7 @@
 #include "chrome/browser/renderer_preferences_util.h"
 
+#include "base/fp_config/fp_config.h"
 #include "base/command_line.h"
 #include "base/i18n/rtl.h"
+#include "base/strings/string_util.h"
 #include "base/notreached.h"
@@ -213,3 +214,16 @@ void UpdateFromSystemSettings(blink::RendererPreferences* prefs,
       blink::ToWebRTCIPHandlingPolicy(
           profile->GetPrefs()->GetString(prefs::kWebRTCIPHandlingPolicy));
+  std::vector<std::string> configured_languages = fp_config::GetStringList("languages");
+  if (fp_config::ModeAllowsOverride("language.mode") &&
+      !configured_languages.empty()) {
+    prefs->accept_languages = base::JoinString(configured_languages, ",");
+  } else if (std::optional<std::string> language =
+                 fp_config::GetString("language.value");
+             fp_config::ModeAllowsOverride("language.mode") && language) {
+    prefs->accept_languages = *language;
+  }
+  if (fp_config::WebRtcProxyUdp()) {
+    prefs->webrtc_ip_handling_policy =
+        blink::WebString::FromASCII("disable_non_proxied_udp").Utf8();
+  }
 }
--- a/content/browser/geolocation/geolocation_provider_impl.cc
+++ b/content/browser/geolocation/geolocation_provider_impl.cc
@@ -5,5 +5,6 @@
 #include "content/browser/geolocation/geolocation_provider_impl.h"
 
+#include "base/fp_config/fp_config.h"
 #include "base/functional/bind.h"
 #include "base/location.h"
 #include "base/task/single_thread_task_runner.h"
@@ -248,5 +249,19 @@ void GeolocationProviderImpl::NotifyClients(
     const device::mojom::Geoposition& position) {
+  if (fp_config::GeolocationDisabled()) {
+    return;
+  }
+  if (fp_config::ModeIs("geolocation.mode", "custom")) {
+    device::mojom::Geoposition spoofed;
+    spoofed.latitude = fp_config::GetDouble("geolocation.latitude").value_or(0);
+    spoofed.longitude = fp_config::GetDouble("geolocation.longitude").value_or(0);
+    spoofed.accuracy = fp_config::GetDouble("geolocation.accuracy").value_or(100);
+    spoofed.timestamp = base::Time::Now();
+    for (const auto& client : clients_) {
+      client->OnLocationUpdate(spoofed);
+    }
+    return;
+  }
   for (const auto& client : clients_) {
     client->OnLocationUpdate(position);
   }
 }
--- a/chrome/browser/geolocation/geolocation_permission_context.cc
+++ b/chrome/browser/geolocation/geolocation_permission_context.cc
@@ -5,4 +5,5 @@
 #include "chrome/browser/geolocation/geolocation_permission_context.h"
 
+#include "base/fp_config/fp_config.h"
 #include "chrome/browser/content_settings/host_content_settings_map_factory.h"
 #include "components/content_settings/core/common/content_settings.h"
@@ -79,7 +80,15 @@ void GeolocationPermissionContext::DecidePermission(
     const permissions::PermissionRequestID& id,
     const GURL& requesting_origin,
     bool user_gesture,
     BrowserPermissionCallback callback) {
+  if (fp_config::GeolocationDisabled()) {
+    std::move(callback).Run(CONTENT_SETTING_BLOCK);
+    return;
+  }
+  if (fp_config::GeolocationAlwaysAllow()) {
+    std::move(callback).Run(CONTENT_SETTING_ALLOW);
+    return;
+  }
   PermissionContextBase::DecidePermission(id, requesting_origin, user_gesture,
                                           std::move(callback));
 }
