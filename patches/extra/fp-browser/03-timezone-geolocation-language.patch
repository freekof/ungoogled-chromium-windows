# Fingerprint browser: timezone, geolocation, language and Accept-Language.

--- a/third_party/blink/renderer/core/frame/navigator_language.cc
+++ b/third_party/blink/renderer/core/frame/navigator_language.cc
@@ -5,6 +5,7 @@
 #include "third_party/blink/renderer/core/frame/navigator_language.h"
 
+#include "base/fp_config/fp_config.h"
 #include "third_party/blink/renderer/platform/language.h"
 
 namespace blink {
@@ -24,6 +25,10 @@ AtomicString NavigatorLanguage::language() {
   const Vector<AtomicString>& languages = this->languages();
   if (!languages.empty())
     return languages[0];
+  if (std::optional<std::string> language =
+          fp_config::GetString("language.value")) {
+    return AtomicString::FromUTF8(*language);
+  }
   return AtomicString();
 }
@@ -42,6 +47,12 @@ const Vector<AtomicString>& NavigatorLanguage::languages() {
     EnsureUpdatedLanguage();
   }
+  std::vector<std::string> configured_languages = fp_config::GetStringList("languages");
+  if (!configured_languages.empty()) {
+    languages_.clear();
+    for (const std::string& language : configured_languages) {
+      languages_.push_back(AtomicString::FromUTF8(language));
+    }
+  } else if (std::optional<std::string> language =
+                 fp_config::GetString("language.value")) {
+    languages_.clear();
+    languages_.push_back(AtomicString::FromUTF8(*language));
+  }
   return languages_;
 }
--- a/chrome/browser/renderer_preferences_util.cc
+++ b/chrome/browser/renderer_preferences_util.cc
@@ -5,6 +5,7 @@
 #include "chrome/browser/renderer_preferences_util.h"
 
