 #include "third_party/icu/source/common/unicode/unistr.h"
@@ -18,6 +19,11 @@ std::u16string GetConfiguredTimeZone() {
   icu::UnicodeString zone;
+  if (std::optional<std::string> timezone =
+          fp_config::GetString("timezone.value")) {
+    zone = icu::UnicodeString::fromUTF8(*timezone);
+    return base::i18n::UnicodeStringToString16(zone);
+  }
   std::unique_ptr<icu::TimeZone> time_zone(icu::TimeZone::createDefault());
   time_zone->getID(zone);
   return base::i18n::UnicodeStringToString16(zone);
