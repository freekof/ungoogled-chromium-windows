+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_FP_PROFILE_FP_PORT_SCAN_THROTTLE_H_
+#define CHROME_BROWSER_FP_PROFILE_FP_PORT_SCAN_THROTTLE_H_
+
+#include "base/fp_config/fp_config.h"
+#include "net/base/net_errors.h"
+#include "services/network/public/cpp/resource_request.h"
+#include "third_party/blink/public/common/loader/url_loader_throttle.h"
+#include "url/gurl.h"
+
+namespace fp_profile {
+
+class FpPortScanThrottle final : public blink::URLLoaderThrottle {
+ public:
+  FpPortScanThrottle() = default;
+  ~FpPortScanThrottle() override = default;
+
+  void WillStartRequest(network::ResourceRequest* request,
+                        bool* defer) override {
+    if (!request) {
+      return;
+    }
+    if (!fp_config::GetBool("port_scan_protection.enabled").value_or(false)) {
+      return;
+    }
+    const GURL& url = request->url;
+    if (!url.is_valid() || !url.SchemeIsHTTPOrHTTPS()) {
+      return;
+    }
+    int port = url.EffectiveIntPort();
+    if (fp_config::IsPrivateOrLocalHost(url.host_piece()) &&
+        !fp_config::IsAllowedPort(port)) {
+      delegate_->CancelWithError(net::ERR_BLOCKED_BY_CLIENT,
+                                 "Blocked by fingerprint port scan protection");
+    }
+  }
+};
+
+}  // namespace fp_profile
+
+#endif  // CHROME_BROWSER_FP_PROFILE_FP_PORT_SCAN_THROTTLE_H_
